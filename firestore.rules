rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSessionParticipant(sessionId) {
      return request.auth.uid in get(/databases/$(database)/documents/sessions/$(sessionId)).data.participants;
    }

    function isMatchParticipant(matchId) {
      return request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users;
    }

    // Group live sessions metadata.
    // All writes are backend-only (Cloud Functions/Admin SDK) to enforce:
    // - capacity checks
    // - host-only status transitions
    // - role assignment integrity
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;

      // In-session chat for group sessions.
      match /chat/{messageId} {
        allow read: if isAuthenticated() && isSessionParticipant(sessionId);
        allow create: if isAuthenticated() &&
          isSessionParticipant(sessionId) &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.createdAt != null;
        allow update, delete: if false;
      }

      // Participant signals managed in Firestore to sync UI (e.g. raise hand).
      match /participantSignals/{uid} {
        allow read: if isAuthenticated() && isSessionParticipant(sessionId);
        allow create, update: if isAuthenticated() &&
          request.auth.uid == uid &&
          isSessionParticipant(sessionId);
        allow delete: if false;
      }
    }

    // 1-to-1 Sessions (Chat/Video calls)
    match /legacy_sessions/{sessionId} {
      // Only participants of the session can read it
      allow read: if isAuthenticated() && request.auth.uid in resource.data.users;
      
      // Updates are handled by the backend to process credits
      allow write: if false;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create, update: if isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.data.id == userId;
      allow delete: if false;
    }

    // Matches
    match /matches/{matchId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.users;
      allow write: if false; // Matches are created by the matching algorithm backend
    }

    // Messages
    match /messages/{matchId}/chat/{messageId} {
      allow read: if isAuthenticated() && isMatchParticipant(matchId);
      allow create: if isAuthenticated() &&
        isMatchParticipant(matchId) &&
        request.resource.data.keys().hasOnly(["match_id", "sender_id", "content", "timestamp", "is_read"]) &&
        request.resource.data.match_id == matchId &&
        request.resource.data.sender_id == request.auth.uid &&
        request.resource.data.content is string &&
        request.resource.data.content.size() > 0 &&
        request.resource.data.content.size() <= 2000 &&
        request.resource.data.timestamp != null &&
        request.resource.data.is_read == false;
      allow update, delete: if false;
    }
  }
}
